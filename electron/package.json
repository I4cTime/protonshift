{
  "name": "protonshift",
  "version": "0.8.5",
  "description": "Linux game configuration toolkit",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter protonshift-renderer dev\" \"pnpm run dev:electron\"",
    "dev:electron": "tsc && electron . --log-level=1",
    "build:renderer": "pnpm --filter protonshift-renderer build",
    "build:electron": "tsc",
    "build": "pnpm run build:renderer && pnpm run build:electron",
    "dist": "pnpm run build && electron-builder --publish never",
    "dist:appimage": "pnpm run build && electron-builder --linux AppImage --publish never",
    "dist:deb": "pnpm run build && electron-builder --linux deb --publish never"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "sharp", "electron-winstaller"]
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^39.8.5",
    "electron-builder": "^26.9.0",
    "typescript": "^5.8.0"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/I4cTime/protonshift.git"
  },
  "bugs": {
    "url": "https://github.com/I4cTime/protonshift/issues"
  },
  "homepage": "https://github.com/I4cTime/protonshift",
  "author": {
    "name": "I4cTime",
    "email": "I4cTime@users.noreply.github.com"
  },
  "build": {
    "appId": "io.github.protonshift",
    "productName": "ProtonShift",
    "directories": {
      "output": "../build"
    },
    "files": [
      "dist/**/*",
      "renderer/out/**/*"
    ],
    "extraResources": [
      {
        "from": "../src",
        "to": "python/src",
        "filter": ["**/*.py", "**/*.css"]
      },
      {
        "from": "../pyproject.toml",
        "to": "python/pyproject.toml"
      },
      {
        "from": "../assets",
        "to": "assets"
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Game",
      "icon": "../assets",
      "desktop": {
        "entry": {
          "Name": "ProtonShift",
          "Comment": "Linux game configuration toolkit",
          "Categories": "Game;Utility;"
        }
      }
    },
    "deb": {
      "depends": ["python3 (>= 3.12)"],
      "maintainer": "I4cTime <I4cTime@users.noreply.github.com>"
    }
  }
}
